#!/bin/sh

COMMIT_MSG_FILE="$1"
FIRST_LINE=$(head -n 1 "$COMMIT_MSG_FILE")

PATTERN='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9._-]+\))?!?: .+'

if echo "$FIRST_LINE" | grep -qE "$PATTERN"; then
  exit 0
fi

echo "❌ Invalid commit message format."
echo ""
echo "The first line must follow Conventional Commits:"
echo "  type[(optional scope)][!]: description"
echo ""
echo "Accepted types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
echo ""
echo "Examples:"
echo "  feat: add new resume template"
echo "  fix(parser): handle empty date fields"
echo "  refactor!: rewrite rendering engine"
echo ""
echo "Your commit message:"
echo "  $FIRST_LINE"
echo ""

exit 1
